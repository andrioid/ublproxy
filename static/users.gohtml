<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Users - ublproxy</title>
<link rel="stylesheet" href="/static/shared.css">
</head>
<body>
{{ template "nav" }}

<main class="main">
  <div id="unauth-view" class="hidden">
    <div class="card auth-card">
      <p class="page-subtitle">You need to <a href="/" style="color:var(--color-primary)">sign in</a> to manage users.</p>
    </div>
  </div>

  <div id="forbidden-view" class="hidden">
    <div class="card auth-card">
      <p class="page-subtitle">Admin access required to manage users.</p>
    </div>
  </div>

  <div id="auth-view" class="hidden">
    <div class="page-header">
      <h1 class="page-title">Users <span class="card-count" id="users-count"></span></h1>
      <p class="page-subtitle">Registered passkey credentials.</p>
    </div>

    <div class="card">
      <ul class="item-list" id="users-list"></ul>
      <div class="empty-state hidden" id="users-empty">No users registered yet.</div>
    </div>
  </div>
</main>

<script src="/static/shared.js"></script>
<script>
(function() {
  'use strict';
  var U = window.ublproxy;

  var usersList = document.getElementById('users-list');
  var usersEmpty = document.getElementById('users-empty');
  var usersCount = document.getElementById('users-count');

  async function loadUsers() {
    try {
      var resp = await fetch('/api/users', { headers: U.authHeaders() });
      if (resp.status === 403) {
        U.hide(document.getElementById('auth-view'));
        U.show(document.getElementById('forbidden-view'));
        return;
      }
      if (!resp.ok) return;
      var users = await resp.json();
      renderUsers(users);
    } catch (_) {}
  }

  function renderUsers(users) {
    usersCount.textContent = '(' + users.length + ')';
    usersList.innerHTML = '';

    if (users.length === 0) {
      U.show(usersEmpty);
      return;
    }
    U.hide(usersEmpty);

    users.forEach(function(user) {
      var li = document.createElement('li');
      li.className = 'item';

      var info = document.createElement('div');
      info.className = 'item-info';

      var nameRow = document.createElement('div');
      nameRow.className = 'item-name';
      var shortId = user.id.length > 12 ? user.id.slice(0, 12) + '\u2026' : user.id;
      nameRow.textContent = shortId;
      nameRow.title = user.id;
      info.appendChild(nameRow);

      var detailRow = document.createElement('div');
      detailRow.className = 'item-url';
      var created = new Date(user.created_at);
      detailRow.textContent = 'Registered ' + created.toLocaleDateString();
      info.appendChild(detailRow);

      li.appendChild(info);

      if (user.is_admin) {
        var badge = document.createElement('span');
        badge.className = 'badge badge-passthrough';
        badge.textContent = 'Admin';
        badge.style.marginLeft = 'auto';
        badge.style.marginRight = '0.5rem';
        li.appendChild(badge);
      }

      var btn = document.createElement('button');
      btn.className = 'btn btn-sm ' + (user.is_admin ? 'btn-danger' : 'btn-secondary');
      btn.textContent = user.is_admin ? 'Revoke Admin' : 'Make Admin';
      btn.addEventListener('click', function() { toggleAdmin(user.id, !user.is_admin); });
      li.appendChild(btn);

      usersList.appendChild(li);
    });
  }

  async function toggleAdmin(id, isAdmin) {
    try {
      var resp = await fetch('/api/users/' + encodeURIComponent(id), {
        method: 'PATCH',
        headers: U.authHeaders(),
        body: JSON.stringify({ is_admin: isAdmin })
      });
      if (resp.status === 403) {
        var err = await resp.json();
        alert(err.error || 'Forbidden');
        return;
      }
      loadUsers();
    } catch (_) {}
  }

  U.authGate(loadUsers, { requireAdmin: true });
})();
</script>
</body>
</html>
